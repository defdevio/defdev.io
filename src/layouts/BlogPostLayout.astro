---
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  frontmatter: {
    title?: string;
    description?: string;
    pubDate?: string | Date;
    date?: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props as Props;
const title = frontmatter.title ?? 'DefDev Blog';
const description = frontmatter.description ?? 'DefDev engineering blog';
const tags = frontmatter.tags ?? [];
---

<Layout title={`${title} | DefDev Blog`} description={description}>
  <main class="min-h-screen bg-zinc-950 text-zinc-100">
    <header class="border-b border-zinc-800/50">
      <div class="max-w-4xl mx-auto px-6 py-6 flex items-center justify-between gap-4">
        <a href="/" class="text-zinc-400 hover:text-white text-sm transition-colors">← Back to defdev.io</a>
        <a href="/blog" class="text-zinc-400 hover:text-purple-300 text-sm transition-colors">All posts</a>
      </div>
    </header>

    <article class="max-w-4xl mx-auto px-6 py-14">
      <p class="text-purple-400 font-medium text-xs uppercase tracking-widest mb-4">DefDev Blog</p>
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight text-white mb-3">{title}</h1>

      {(frontmatter.pubDate || frontmatter.date) && (
        <p class="text-zinc-500 text-sm mb-6">Published {new Date(frontmatter.pubDate ?? frontmatter.date ?? '').toLocaleDateString()}</p>
      )}

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {tags.map((tag) => (
            <span class="text-xs font-medium bg-zinc-900 text-zinc-300 border border-zinc-700 px-2.5 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}

      <div class="blog-content">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .blog-content {
    color: #d4d4d8;
    line-height: 1.8;
    font-size: 1rem;
  }

  .blog-content :global(h2) {
    color: #ffffff;
    font-size: 1.7rem;
    line-height: 1.3;
    font-weight: 700;
    margin-top: 2.3rem;
    margin-bottom: 0.9rem;
  }

  .blog-content :global(h3) {
    color: #ffffff;
    font-size: 1.2rem;
    line-height: 1.4;
    font-weight: 600;
    margin-top: 1.7rem;
    margin-bottom: 0.6rem;
  }

  .blog-content :global(p) {
    margin-top: 0.9rem;
    margin-bottom: 0.9rem;
  }

  .blog-content :global(ul) {
    list-style-type: disc;
    margin-top: 0.75rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .blog-content :global(ol) {
    list-style-type: decimal;
    margin-top: 0.75rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .blog-content :global(li) {
    margin: 0.35rem 0;
  }

  .blog-content :global(code) {
    color: #e9d5ff;
    background: rgba(63, 63, 70, 0.7);
    border: 1px solid rgba(82, 82, 91, 0.8);
    border-radius: 0.35rem;
    padding: 0.1rem 0.35rem;
    font-size: 0.92em;
  }

  .blog-content :global(pre) {
    background: #09090b;
    border: 1px solid #27272a;
    border-radius: 0.75rem;
    padding: 1rem;
    overflow-x: auto;
    margin: 1.1rem 0;
  }

  .blog-content :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
    color: #e4e4e7;
  }

  .blog-content :global(a) {
    color: #c4b5fd;
    text-decoration: underline;
    text-decoration-color: rgba(196, 181, 253, 0.45);
    text-underline-offset: 0.2rem;
  }

  .blog-content :global(a:hover) {
    color: #ddd6fe;
  }

  .blog-content :global(blockquote) {
    border-left: 3px solid #6d28d9;
    margin: 1.2rem 0;
    padding: 0.2rem 0 0.2rem 1rem;
    color: #a1a1aa;
  }

  .blog-content :global(hr) {
    border: 0;
    border-top: 1px solid #27272a;
    margin: 2rem 0;
  }
</style>
