---
---

<section id="contact" class="py-28 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-purple-400 font-medium text-xs uppercase tracking-widest mb-3">Let's Talk</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Work With Me</h2>
      <div class="h-px w-16 bg-purple-700 mx-auto rounded-full"></div>
      <p class="text-zinc-400 mt-6 text-sm leading-relaxed">
        Tell me about your project and I'll be in touch shortly.
      </p>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8">
      <!-- Form -->
      <form id="contact-form" class="space-y-5" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="clientName" class="block text-sm font-medium text-zinc-300 mb-1.5">Company name</label>
            <input
              type="text"
              id="clientName"
              name="clientName"
              required
              class="w-full bg-zinc-800 border border-zinc-700 focus:border-purple-700 focus:ring-1 focus:ring-purple-700/50 rounded-md px-4 py-2.5 text-white placeholder-zinc-600 outline-none transition-colors text-sm"
            />
            <p id="error-clientName" class="mt-1.5 text-xs text-red-400 hidden"></p>
          </div>
          <div>
            <label for="phoneNumber" class="block text-sm font-medium text-zinc-300 mb-1.5">Phone number</label>
            <input
              type="tel"
              id="phoneNumber"
              name="phoneNumber"
              placeholder="123-456-7890"
              pattern="^\d{3}-\d{3}-\d{4}$"
              inputmode="numeric"
              required
              class="w-full bg-zinc-800 border border-zinc-700 focus:border-purple-700 focus:ring-1 focus:ring-purple-700/50 rounded-md px-4 py-2.5 text-white placeholder-zinc-600 outline-none transition-colors text-sm"
            />
            <p id="error-phoneNumber" class="mt-1.5 text-xs text-red-400 hidden"></p>
          </div>
        </div>

        <div>
          <label for="clientEmailAddress" class="block text-sm font-medium text-zinc-300 mb-1.5">Email address</label>
          <input
            type="email"
            id="clientEmailAddress"
            name="emailAddress"
            placeholder="name@example.com"
            required
            class="w-full bg-zinc-800 border border-zinc-700 focus:border-purple-700 focus:ring-1 focus:ring-purple-700/50 rounded-md px-4 py-2.5 text-white placeholder-zinc-600 outline-none transition-colors text-sm"
          />
          <p id="error-clientEmailAddress" class="mt-1.5 text-xs text-red-400 hidden"></p>
        </div>

        <div>
          <label for="description" class="block text-sm font-medium text-zinc-300 mb-1.5">Project description</label>
          <textarea
            id="description"
            name="projectDescription"
            rows="4"
            required
            class="w-full bg-zinc-800 border border-zinc-700 focus:border-purple-700 focus:ring-1 focus:ring-purple-700/50 rounded-md px-4 py-2.5 text-white placeholder-zinc-600 outline-none transition-colors resize-none text-sm"
          ></textarea>
          <p id="error-description" class="mt-1.5 text-xs text-red-400 hidden"></p>
        </div>

        <div>
          <label for="cloudProviders" class="block text-sm font-medium text-zinc-300 mb-1.5">Preferred cloud provider</label>
          <input
            list="cloudProviderOptions"
            id="cloudProviders"
            name="preferredCloudProvider"
            placeholder="Click to choose or type to search..."
            required
            class="w-full bg-zinc-800 border border-zinc-700 focus:border-purple-700 focus:ring-1 focus:ring-purple-700/50 rounded-md px-4 py-2.5 text-white placeholder-zinc-600 outline-none transition-colors text-sm"
          />
          <datalist id="cloudProviderOptions">
            <option value="AWS" />
            <option value="Azure" />
            <option value="GCP" />
            <option value="Oracle Cloud" />
            <option value="Digital Ocean" />
            <option value="Other" />
            <option value="No preference" />
          </datalist>
          <p id="error-cloudProviders" class="mt-1.5 text-xs text-red-400 hidden"></p>
        </div>

        <!-- Cloudflare Turnstile -->
        <div class="cf-turnstile" data-sitekey="0x4AAAAAAA7Pk3U2XtAtjzfI"></div>

        <!-- Submit button states -->
        <div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-purple-700 hover:bg-purple-800 text-white py-3 rounded-md font-semibold transition-colors text-sm shadow-lg shadow-purple-900/20"
          >
            Send Message
          </button>
          <button
            type="button"
            id="submit-send-btn"
            style="display:none"
            disabled
            class="w-full bg-zinc-700 text-zinc-300 py-3 rounded-md font-semibold text-sm flex items-center justify-center gap-2 cursor-not-allowed"
          >
            <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            Sending...
          </button>
          <button
            type="button"
            id="success-btn"
            style="display:none"
            class="w-full bg-emerald-700 text-white py-3 rounded-md font-semibold text-sm flex items-center justify-center gap-2"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Sent!
          </button>
          <button
            type="button"
            id="error-btn"
            style="display:none"
            class="w-full bg-red-800/80 text-white py-3 rounded-md font-semibold text-sm flex items-center justify-center gap-2"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
            </svg>
            Error sending — please try again
          </button>
        </div>
      </form>

      <!-- Success state (replaces form) -->
      <div id="success-message" style="display:none" class="text-center py-10">
        <div class="w-16 h-16 bg-emerald-900/40 rounded-full flex items-center justify-center mx-auto mb-5 ring-1 ring-emerald-700/40">
          <svg class="h-8 w-8 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Message Sent!</h3>
        <p class="text-zinc-400 leading-relaxed text-sm">
          Thanks for reaching out to <span class="text-purple-400">DefDev</span>. I will be in touch
          shortly to discuss next steps. I look forward to working with you!
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const SUBMIT_URL = import.meta.env.DEV
    ? '/api/contact'
    : 'https://vh4tf5xws5.execute-api.us-west-2.amazonaws.com/prod/contact';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn');
  const submitSendBtn = document.getElementById('submit-send-btn');
  const successBtn = document.getElementById('success-btn');
  const errorBtn = document.getElementById('error-btn');
  const successMessage = document.getElementById('success-message');

  const allowedProviders = new Set([
    'aws',
    'azure',
    'gcp',
    'oracle cloud',
    'digital ocean',
    'other',
    'no preference',
  ]);

  function getEl<T extends HTMLElement>(id: string): T | null {
    return document.getElementById(id) as T | null;
  }

  function setFieldError(fieldId: string, message: string) {
    const field = getEl<HTMLInputElement | HTMLTextAreaElement>(fieldId);
    const error = getEl<HTMLElement>(`error-${fieldId}`);
    if (field) {
      field.classList.add('border-red-500');
      field.setAttribute('aria-invalid', 'true');
    }
    if (error) {
      error.textContent = message;
      error.classList.remove('hidden');
    }
  }

  function clearFieldError(fieldId: string) {
    const field = getEl<HTMLInputElement | HTMLTextAreaElement>(fieldId);
    const error = getEl<HTMLElement>(`error-${fieldId}`);
    if (field) {
      field.classList.remove('border-red-500');
      field.removeAttribute('aria-invalid');
    }
    if (error) {
      error.textContent = '';
      error.classList.add('hidden');
    }
  }

  function normalize(value: FormDataEntryValue | null): string {
    return typeof value === 'string' ? value.trim() : '';
  }

  function isValidEmail(value: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value);
  }

  function isValidPhone(value: string): boolean {
    return /^\d{3}-\d{3}-\d{4}$/.test(value);
  }

  function validateField(fieldId: string, formData: FormData): boolean {
    clearFieldError(fieldId);

    const clientName = normalize(formData.get('clientName'));
    const phoneNumber = normalize(formData.get('phoneNumber'));
    const emailAddress = normalize(formData.get('emailAddress'));
    const projectDescription = normalize(formData.get('projectDescription'));
    const preferredCloudProvider = normalize(formData.get('preferredCloudProvider'));

    if (fieldId === 'clientName') {
      if (clientName.length < 2) {
        setFieldError('clientName', 'Please provide your company name.');
        return false;
      }
      return true;
    }

    if (fieldId === 'phoneNumber') {
      if (!isValidPhone(phoneNumber)) {
        setFieldError('phoneNumber', 'Use format ddd-ddd-dddd (example: 123-456-7890).');
        return false;
      }
      return true;
    }

    if (fieldId === 'clientEmailAddress') {
      if (!isValidEmail(emailAddress)) {
        setFieldError('clientEmailAddress', 'Enter a valid email address (e.g., name@company.com).');
        return false;
      }
      return true;
    }

    if (fieldId === 'description') {
      if (projectDescription.length < 20) {
        setFieldError('description', 'Please provide a project description (at least 20 characters).');
        return false;
      }
      return true;
    }

    if (fieldId === 'cloudProviders') {
      if (!preferredCloudProvider) {
        setFieldError('cloudProviders', 'Please select your preferred cloud provider.');
        return false;
      }
      if (!allowedProviders.has(preferredCloudProvider.toLowerCase())) {
        setFieldError('cloudProviders', 'Choose a provider from the list (or select Other / No preference).');
        return false;
      }
      return true;
    }

    return true;
  }

  function validateForm(formData: FormData): boolean {
    let isValid = true;
    const fields = ['clientName', 'phoneNumber', 'clientEmailAddress', 'description', 'cloudProviders'];

    fields.forEach((fieldId) => {
      if (!validateField(fieldId, formData)) {
        isValid = false;
      }
    });

    return isValid;
  }

  const validationMap: Record<string, string> = {
    clientName: 'clientName',
    phoneNumber: 'phoneNumber',
    clientEmailAddress: 'clientEmailAddress',
    description: 'description',
    cloudProviders: 'cloudProviders',
  };

  Object.entries(validationMap).forEach(([id, fieldId]) => {
    const input = getEl<HTMLInputElement | HTMLTextAreaElement>(id);
    input?.addEventListener('input', () => clearFieldError(fieldId));
    input?.addEventListener('blur', () => {
      const fd = form ? new FormData(form) : new FormData();
      validateField(fieldId, fd);
    });
  });

  function showOnly(id: string) {
    [submitBtn, submitSendBtn, successBtn, errorBtn].forEach((el) => {
      if (el) el.style.display = 'none';
    });
    const target = document.getElementById(id);
    if (target) target.style.display = '';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const isValid = validateForm(formData);
    if (!isValid) {
      showOnly('submit-btn');
      return;
    }

    showOnly('submit-send-btn');

    console.log('[contact] submitting to', SUBMIT_URL);

    try {
      const payload = Object.fromEntries(formData);
      console.log('[contact] payload keys:', Object.keys(payload));

      const response = await fetch(SUBMIT_URL, {
        method: 'POST',
        body: JSON.stringify(payload),
        headers: { 'Content-Type': 'application/json' },
      });

      const body = await response.text();

      if (response.ok) {
        console.log('[contact] success', response.status);
        if (form) form.style.display = 'none';
        if (successMessage) successMessage.style.display = '';
      } else {
        console.error('[contact] submit failed', response.status, body);
        showOnly('error-btn');
      }
    } catch (err) {
      const message = err instanceof Error ? `${err.name}: ${err.message}` : String(err);
      console.error('[contact] fetch threw', message, err);
      showOnly('error-btn');
    }
  });
</script>
