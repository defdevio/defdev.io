---
const projects = [
  {
    name: 'OpenDepot',
    tagline: 'Self-hosted OpenTofu & Terraform registry',
    description:
      'A Kubernetes-native module and provider registry built for teams that want full ownership of their IaC supply chain — no JFrog required.',
    badge: 'Open Source',
    badgeClass: 'bg-emerald-900/50 text-emerald-400 border border-emerald-700/40',
    icon: '📦',
    tags: ['Kubernetes', 'OpenTofu', 'Terraform', 'Go'],
    links: [
      { label: 'Docs', href: 'https://tonedefdev.github.io/opendepot/', type: 'docs' },
      { label: 'GitHub', href: 'https://github.com/tonedefdev/opendepot', type: 'github' },
    ],
  },
  {
    name: 'ferme',
    tagline: 'End-to-end MLOps pipeline for IaC security fine-tuning',
    description:
      'Discovers and scores every module in the OpenTofu Registry via a concurrent Go ingester (Trivy + TFLint), curates QLoRA-ready training pairs using a teacher LLM, and fine-tunes security-aware IaC code models — all in a reproducible, phase-driven pipeline.',
    badge: 'MLOps',
    badgeClass: 'bg-blue-900/50 text-blue-400 border border-blue-700/40',
    logo: '/img/ferme_logo_dark.svg',
    tags: ['Python', 'Go', 'QLoRA', 'LLMs', 'IaC Security', 'Data Pipelines'],
    links: [
      { label: 'GitHub', href: 'https://github.com/tonedefdev/ferme', type: 'github' },
    ],
  },
  {
    name: 'terracreds',
    tagline: 'Credential helper for Terraform & OpenTofu',
    description:
      'Securely store and retrieve Terraform and OpenTofu credentials using your OS keychain or cloud secret managers — no plaintext secrets on disk.',
    badge: 'Security',
    badgeClass: 'bg-amber-900/50 text-amber-400 border border-amber-700/40',
    logo: '/img/terracreds.png',
    tags: ['Go', 'Security', 'Terraform', 'OpenTofu'],
    links: [
      { label: 'GitHub', href: 'https://github.com/tonedefdev/terracreds', type: 'github' },
    ],
  },
];
---

<section id="projects" class="py-28 px-6 bg-zinc-900/40">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-purple-400 font-medium text-xs uppercase tracking-widest mb-3">Open Source</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Projects</h2>
      <div class="h-px w-16 bg-purple-700 mx-auto rounded-full"></div>
      <p class="text-zinc-400 mt-6 max-w-lg mx-auto text-sm leading-relaxed">
        Tools built from real-world problems. All open source, all battle-tested.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <div class="bg-zinc-900 border border-zinc-800 hover:border-purple-700/50 rounded-xl p-6 flex flex-col transition-all duration-200 group hover:shadow-xl hover:shadow-purple-900/10">
            <!-- Icon + badge row -->
            <div class="flex items-center justify-between mb-5">
              <div class="h-12 flex items-center">
                {project.logo
                  ? <img src={project.logo} alt={project.name} class={project.logo.endsWith('.png') ? 'h-12 w-12 object-contain' : 'h-7'} />
                  : <span class="text-3xl leading-none">{project.icon}</span>
                }
              </div>
              <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${project.badgeClass}`}>
                {project.badge}
              </span>
            </div>

            <!-- Title + tagline -->
            <h3 class="text-lg font-bold text-white mb-1 group-hover:text-purple-300 transition-colors">
              {project.name}
            </h3>
            <p class="text-purple-400/80 text-xs font-medium mb-3">{project.tagline}</p>

            <!-- Description -->
            <p class="text-zinc-400 text-sm leading-relaxed flex-1 mb-5">{project.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.tags.map((tag) => (
                <span class="text-xs bg-zinc-800 text-zinc-500 px-2 py-0.5 rounded font-mono">{tag}</span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex gap-4 pt-1 border-t border-zinc-800 mt-auto">
              {project.links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-sm text-zinc-400 hover:text-purple-400 transition-colors font-medium pt-3"
                >
                  {link.type === 'github' ? (
                    <svg class="h-4 w-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.746 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                    </svg>
                  ) : (
                    <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                  )}
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
