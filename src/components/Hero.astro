---
---

<section id="home" class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-16">
  <!-- Subtle radial glow behind logo -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
    <div class="w-[600px] h-[600px] rounded-full bg-purple-700/10 blur-3xl"></div>
  </div>

  <div class="relative z-10 flex flex-col items-center">
    <img
      src="/img/white_logo.svg"
      alt="DefDev"
      class="w-40 sm:w-56 lg:w-72 mb-10 drop-shadow-2xl"
    />

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-5 tracking-tight leading-tight">
      Technology Consultants
    </h1>

    <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mb-3 leading-relaxed">
      Cloud infrastructure, software delivery, and automation experts —
    </p>
    <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mb-12 leading-relaxed">
      ready to accelerate your organization's digital transformation.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="#contact"
        class="bg-purple-700 hover:bg-purple-800 text-white px-8 py-3.5 rounded-md text-base font-semibold transition-colors shadow-lg shadow-purple-900/30"
      >
        Work With Me
      </a>
      <a
        href="#projects"
        class="border border-zinc-700 hover:border-purple-700/60 hover:bg-zinc-800/50 text-zinc-300 hover:text-white px-8 py-3.5 rounded-md text-base font-semibold transition-colors"
      >
        See My Work
      </a>
    </div>

    <!-- Scroll indicator sits inside the centered group, consistent on all viewports -->
    <div class="mt-12 animate-bounce">
      <svg class="h-5 w-5 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>
