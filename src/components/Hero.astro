---
---

<section id="home" class="relative min-h-[calc(100svh-4rem)] sm:min-h-[calc(100vh-4rem)] overflow-hidden flex flex-col items-center justify-start short:justify-center text-center px-6 pt-8 sm:pt-12 lg:pt-16 short:pt-4 pb-16 short:pb-8">
  <!-- Subtle radial glow behind logo -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
    <div class="w-[500px] h-[500px] sm:w-[700px] sm:h-[700px] rounded-full bg-purple-700/15 sm:bg-purple-700/10 blur-3xl"></div>
  </div>

  <!-- iOS WebKit-only boost to preserve glow character without a full gradient overlay -->
  <div class="hero-ios-glow-boost" aria-hidden="true"></div>

  <div class="relative z-10 flex flex-col items-center">
    <img
      src="/img/white_logo_mini.svg"
      alt="DefDev"
      class="w-40 sm:w-56 lg:w-72 short:w-32 mb-6 sm:mb-10 short:mb-3 drop-shadow-2xl"
    />

    <h1 class="text-4xl sm:text-5xl lg:text-6xl short:text-3xl font-bold text-white mb-5 short:mb-2 tracking-tight leading-tight">
      Cloud &amp; Platform Engineering
    </h1>

    <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mb-3 short:mb-1 leading-relaxed short:text-base">
      IaC, cloud-native architecture, and AI-augmented delivery —
    </p>
    <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mb-8 sm:mb-12 short:mb-4 leading-relaxed short:text-base">
      available for consulting engagements across AWS, Azure, and GCP.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="#contact"
        class="bg-purple-700 hover:bg-purple-800 text-white px-8 py-3.5 rounded-md text-base font-semibold transition-colors shadow-lg shadow-purple-900/30"
      >
        Work With Me
      </a>
      <a
        href="#projects"
        class="border border-zinc-700 hover:border-purple-700/60 hover:bg-zinc-800/50 text-zinc-300 hover:text-white px-8 py-3.5 rounded-md text-base font-semibold transition-colors"
      >
        See My Work
      </a>
    </div>

    <!-- Scroll indicator centered relative to CTA buttons -->
    <div class="mt-10 sm:mt-12 animate-bounce" aria-hidden="true">
      <svg class="h-5 w-5 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

  <!-- Blend hero glow into the next section so there is no hard color cutoff -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 h-28 sm:h-36 bg-gradient-to-b from-transparent via-zinc-950/80 to-zinc-950"
  ></div>

</section>

<style>
  .hero-ios-glow-boost {
    display: none;
  }

  @supports (-webkit-touch-callout: none) {
    @media (hover: none) and (pointer: coarse) {
      .hero-ios-glow-boost {
        display: block;
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(circle at 50% 34%, rgba(126, 34, 206, 0.24) 0%, rgba(126, 34, 206, 0.1) 33%, rgba(9, 9, 11, 0) 68%);
      }
    }
  }
</style>
