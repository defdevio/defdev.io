---
import awsDiagram from '../data/aws-diagram.json';
const mxgraphJson = JSON.stringify(awsDiagram);

const services = [
  {
    icon: '/img/public_cloud_providers.svg',
    title: 'Public Cloud',
    description:
      'Proven track record helping organizations of any size accelerate market delivery and reduce costs when migrating to AWS, Azure, or GCP.',
  },
  {
    icon: '/img/terraform.svg',
    title: 'Infrastructure as Code',
    description:
      'Custom OpenTofu and Terraform modules built to your business and regulatory needs — monolith, microservices, or event-driven architecture.',
  },
  {
    icon: '/img/cloud_native.svg',
    title: 'Cloud Native',
    description:
      'Kubernetes, containers, and GitOps expertise to help you deliver worry-free, seamless deployments to any environment, at any scale.',
  },
];

const philosophy = [
  {
    icon: '/img/git_pull_request.svg',
    title: 'Code First Philosophy',
    description:
      'Every project ships with comprehensive code ensuring reliability and consistency across environments of any scale — fully documented and auditable through GitHub or your preferred VCS.',
  },
  {
    icon: '/img/cloud_migrate.svg',
    title: 'Migrate with Confidence',
    description:
      'Experience across cannabis, finance, banking, hospitality, and healthcare — navigating complex, regulated environments to achieve your digital transformation objectives.',
  },
  {
    svgPaths: [
      { d: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z', stroke: '#ffffff' },
      { d: 'M18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z', stroke: '#a78bfa' },
      { d: 'M16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423L16.5 15.75l.394 1.183a2.25 2.25 0 001.423 1.423L19.5 18.75l-1.183.394a2.25 2.25 0 00-1.423 1.423z', stroke: '#a78bfa' },
    ],    title: 'AI-Augmented Engineering',
    description:
      'AI fluency is now a competitive requirement — not a differentiator. I embed agentic workflows, intelligent automation, and LLM tooling directly into infrastructure and development lifecycles so your team moves faster without introducing risk.',
  },
];
---

<section id="services" class="py-28 px-6 bg-zinc-900/40">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-purple-400 font-medium text-xs uppercase tracking-widest mb-3">Services</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">What I Do</h2>
      <div class="h-px w-16 bg-purple-700 mx-auto rounded-full"></div>
      <p class="text-zinc-400 mt-6 max-w-xl mx-auto text-sm leading-relaxed">
        DefDev specializes in cloud infrastructure, IaC, and cloud-native engineering. No ClickOps. No shortcuts.
      </p>
    </div>

    <!-- Core services -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-24">
      {
        services.map((service) => (
          <div class="text-center flex flex-col items-center">
            <img src={service.icon} alt={service.title} class="h-28 mb-6 opacity-90" />
            <h3 class="text-base font-semibold text-white mb-2">{service.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">{service.description}</p>
          </div>
        ))
      }
    </div>

    <!-- Philosophy row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {
        philosophy.map((item) => (
          <div class="bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl p-6 text-center flex flex-col items-center transition-colors">
            {item.svgPaths
              ? <svg class="h-20 mb-4 opacity-80" fill="none" viewBox="0 0 24 24" stroke-width="1.2">{item.svgPaths.map((p) => <path stroke-linecap="round" stroke-linejoin="round" d={p.d} stroke={p.stroke} />)}</svg>
              : <img src={item.icon} alt={item.title} class="h-20 mb-4 opacity-80" />
            }
            <h3 class="text-sm font-semibold text-white mb-2">{item.title}</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))
      }
    </div>

    <!-- AI & ML highlight row -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8 mb-16">
      <div class="flex flex-col md:flex-row items-start md:items-center gap-6 mb-8">
        <img src="/img/ferme_logo_dark.svg" alt="ferme" class="h-8 flex-shrink-0" />
        <div>
          <h3 class="text-base font-semibold text-white">AI & Machine Learning</h3>
          <p class="text-zinc-400 text-sm mt-1 leading-relaxed">
            Building agentic workflows, data ingestion pipelines, and fine-tuned models that put domain knowledge
            directly into the model weights — not just the prompt.
          </p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          {
            title: 'Agentic AI',
            desc: 'Multi-step autonomous workflows that plan, execute, and self-correct — grounded in real infrastructure context.',
            icon: 'M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5',
          },
          {
            title: 'Data Ingestion Pipelines',
            desc: 'High-throughput concurrent pipelines in Go and Python — from API discovery through scoring, filtering, and structured output.',
            icon: 'M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z',
          },
          {
            title: 'Model Fine-Tuning',
            desc: 'QLoRA and supervised fine-tuning of open-weight LLMs using carefully curated, domain-specific training pairs and teacher-student pipelines.',
            icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
          },
          {
            title: 'LLM Workflows',
            desc: 'Teacher-student generation, quality filtering, dataset versioning, and Ollama-backed local inference — all production-grade.',
            icon: 'M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z',
          },
        ].map((item) => (
          <div class="bg-zinc-800/50 rounded-lg p-4 border border-zinc-700/40">
            <div class="w-8 h-8 rounded-md bg-purple-900/50 flex items-center justify-center mb-3">
              <svg class="h-4 w-4 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h4 class="text-sm font-semibold text-white mb-1">{item.title}</h4>
            <p class="text-zinc-500 text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- AWS architecture callout -->
    <div class="border-t border-zinc-800/50 pt-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- draw.io architecture diagram -->
        <div class="order-2 md:order-1 bg-zinc-900/60 rounded-xl p-4 border border-zinc-800">
          <div class="mxgraph" style="max-width:100%;" data-mxgraph={mxgraphJson}></div>
        </div>

        <!-- Text -->
        <div class="order-1 md:order-2">
          <h3 class="text-2xl font-bold text-white mb-4">
            This site operates on native <span class="text-amber-400">AWS</span> technology
          </h3>
          <p class="text-zinc-400 text-sm leading-relaxed mb-5">
            I use <span class="text-purple-400">S3 Static Website</span> and <span class="text-purple-400">CloudFront</span> for asset distribution.
            With <span class="text-purple-400">API Gateway</span>, <span class="text-purple-400">Lambda Functions</span>, and
            <span class="text-purple-400">Simple Email Service</span> I run a low-cost, secure, serverless site, fully
            automated with <span class="text-purple-400">Dagger</span> and <span class="text-purple-400">Terraform</span> modules.
          </p>
          <a
            href="https://github.com/defdevio/defdev.io"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-purple-400 hover:text-purple-300 transition-colors font-medium"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.746 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            github.com/defdevio/defdev.io
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="text/javascript" src="https://viewer.diagrams.net/js/viewer-static.min.js"></script>
