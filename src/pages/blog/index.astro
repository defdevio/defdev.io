---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => ({
    url: `/blog/${post.slug}`,
    title: post.data.title,
    description: post.data.description,
    date: post.data.pubDate,
    tags: post.data.tags,
  }));
---

<Layout title="DefDev Blog" description="Thoughts on Kubernetes, Cloud Native, and platform engineering.">
  <main class="min-h-screen bg-zinc-950 text-zinc-100">
    <header class="border-b border-zinc-800/50">
      <div class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-between gap-4">
        <a href="/" class="text-zinc-400 hover:text-white text-sm transition-colors">← Back to defdev.io</a>
      </div>
    </header>

    <section class="max-w-5xl mx-auto px-6 py-14">
      <p class="text-purple-400 font-medium text-xs uppercase tracking-widest mb-3">Writing</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">DefDev Blog</h1>
      <p class="text-zinc-400 max-w-2xl text-sm sm:text-base leading-relaxed mb-10">
        Practical posts on Kubernetes, cloud-native architecture, platform engineering, and open source projects built in public.
      </p>

      <div class="grid gap-6">
        {posts.map((post) => (
          <a
            href={post.url}
            class="group block bg-zinc-900 border border-zinc-800 hover:border-purple-700/50 rounded-xl p-7 transition-all duration-200 hover:shadow-xl hover:shadow-purple-900/10"
          >
            <div class="flex flex-wrap items-center gap-2 mb-4">
              {post.tags.slice(0, 3).map((tag: string) => (
                <span class="text-xs font-medium bg-zinc-800 text-zinc-300 border border-zinc-700 px-2.5 py-1 rounded-full">{tag}</span>
              ))}
              {post.date && <span class="text-zinc-600 text-xs ml-1">{post.date.toLocaleDateString()}</span>}
            </div>

            <h2 class="text-xl font-bold text-white mb-3 group-hover:text-purple-300 transition-colors leading-snug">{post.title}</h2>
            <p class="text-zinc-400 leading-relaxed text-sm">{post.description}</p>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
